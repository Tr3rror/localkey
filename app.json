{
  "expo": {
    "name": "localkey",
    "slug": "localkey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo-icons/icon.png",
    "scheme": "localkey",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/expo-icons/adaptive-icon.png",
        "backgroundImage": "./assets/expo-icons/adaptive-icon.png",
        "monochromeImage": "./assets/expo-icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tr3rr0r.localkey"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo-icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/expo-icons/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
